# ============================================================
# ABCare OmniFlow — Environment Configuration
# Copy this file to .env and fill in your values
#   Linux/Mac:  cp .env.example .env
#   Windows:    Copy-Item .env.example .env
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────
# For Docker deployment (uses the postgres container):
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# For local development (uses local Supabase):
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── App ────────────────────────────────────────────────────────────────────
APP_PORT=3000
NODE_ENV=production

# ── AI / Ollama ────────────────────────────────────────────────────────────
# For Docker deployment (uses the ollama container):
OLLAMA_HOST=http://ollama:11434

# For local development:
# OLLAMA_HOST=http://localhost:11434

DEFAULT_MODEL=llama3.2
VISION_MODEL=llava

# ── Security — GENERATE NEW VALUES FOR PRODUCTION ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_random_64_char_hex_string
SESSION_SECRET=CHANGE_ME_generate_another_random_64_char_hex_string

# ── Google OAuth (Optional) ────────────────────────────────────────────────
# Leave blank to disable Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Comma-separated list of allowed Gmail addresses
GOOGLE_ALLOWED_EMAILS=

# ── SMS Reminders (Semaphore API) ──────────────────────────────────────────
# Get your API key from https://semaphore.co
SMS_API_URL=https://api.semaphore.co/api/v4/messages
SMS_API_KEY=
SMS_SENDER_NAME=ABCClinic

# ── Gemini API (Optional — for AI features) ───────────────────────────────
GEMINI_API_KEY=
