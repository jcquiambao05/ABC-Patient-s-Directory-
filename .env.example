# ── ABCare OmniFlow — Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your values before running docker compose

# ── Database (auto-configured for Docker, change only if using external DB) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# ── AI / Ollama ───────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=llama3.2
VISION_MODEL=llava

# ── Security (REQUIRED — generate strong random strings) ─────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret_here
SESSION_SECRET=CHANGE_ME_generate_a_different_strong_random_secret_here

# ── Google OAuth (OPTIONAL — leave blank to disable Google sign-in) ───────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Comma-separated list of allowed Google account emails
GOOGLE_ALLOWED_EMAILS=

# ── Gemini API (OPTIONAL — only needed if using Gemini instead of Ollama) ─
GEMINI_API_KEY=
