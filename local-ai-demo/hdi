#!/usr/bin/env python3
"""
============================================================
TOOL 2: "How Do I?" Terminal Assistant (hdi)
============================================================
Forget a Linux command? Just ask in plain English.
The AI outputs ONLY the exact bash command — nothing else.

USAGE:
  ./hdi find all PDF files larger than 50MB and delete them
  ./hdi list all running processes sorted by memory
  ./hdi compress a folder into a tar.gz file
  ./hdi show disk usage of each folder in current directory

SETUP (run once):
  chmod +x hdi
  sudo cp hdi /usr/local/bin/hdi   ← makes it available everywhere

REQUIRES:
  - Ollama running: ollama serve
  - llama3.2 pulled: ollama pull llama3.2
============================================================
"""

import sys
import json
import urllib.request
import urllib.error

OLLAMA_URL = "http://localhost:11434/api/chat"
MODEL      = "llama3.2"

# ── System prompt — the strictest guardrail possible ─────────
# This forces the AI to output ONLY a bash command.
# No explanation, no markdown, no code blocks — just the command.
SYSTEM_PROMPT = """You are a Linux terminal expert.
The user will describe what they want to do in plain English.
You MUST output ONLY the raw bash command that does it.

STRICT RULES:
- Output ONLY the command itself
- NO explanations
- NO markdown formatting
- NO code blocks (no backticks)
- NO "Here is the command:" prefix
- If multiple commands are needed, join them with && or ;
- If unsure, output the most common/safe version

Example input:  list all files larger than 100MB
Example output: find . -type f -size +100M -ls"""


def call_ollama(question: str) -> str:
    """Ask the AI for a bash command."""
    
    payload = {
        "model": MODEL,
        "stream": False,
        "messages": [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user",   "content": question}
        ]
    }
    
    data = json.dumps(payload).encode('utf-8')
    req  = urllib.request.Request(
        OLLAMA_URL,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST"
    )
    
    try:
        with urllib.request.urlopen(req, timeout=30) as response:
            result = json.loads(response.read())
            # Clean up any accidental markdown the AI might add
            cmd = result["message"]["content"].strip()
            cmd = cmd.strip('`')
            if cmd.startswith('bash\n'): cmd = cmd[5:]
            if cmd.startswith('sh\n'):   cmd = cmd[3:]
            return cmd.strip()
    except urllib.error.URLError:
        return "# ERROR: Ollama not running. Start it with: ollama serve"
    except Exception as e:
        return f"# ERROR: {e}"


def main():
    if len(sys.argv) < 2:
        print("Usage: hdi <what you want to do>")
        print("")
        print("Examples:")
        print("  hdi find all PDF files larger than 50MB")
        print("  hdi show disk usage sorted by size")
        print("  hdi kill all processes named python")
        print("  hdi compress folder mydir into mydir.tar.gz")
        sys.exit(1)
    
    # Join all arguments into the question
    question = " ".join(sys.argv[1:])
    
    # Call the AI
    command = call_ollama(question)
    
    # Output ONLY the command — clean, copy-pasteable
    print(command)


if __name__ == "__main__":
    main()
